{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "npm run install:all --prefix system",
  "buildCommand": "npm run build:vercel --prefix system",
  "outputDirectory": "system/client/dist",
  "functions": {
    "system/api/[...slug].js": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/system/api/[...slug].js" },
    { "source": "/((?!.*\\.).*)", "destination": "/index.html" }
  ]
}
