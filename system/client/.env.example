# نفس مشروع Supabase — للاستخدام الاختياري من المتصفح (استعلامات مباشرة)
# انسخ إلى .env وعدّل الأسماء: Vite يتطلب البادئة VITE_
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# إذا كان الـ API يعيد مسار صورة نسبياً (بدون https)
# VITE_IMAGE_URL_PREFIX=https://minizoo.qa
# أو CDN ميني زو (نفس فكرة PUBLIC_IMAGE_BASE_URL على السيرفر):
# VITE_IMAGE_URL_PREFIX=https://d3g5vfdhxupk5f.cloudfront.net
# VITE_PUBLIC_IMAGE_BASE_URL=https://d3g5vfdhxupk5f.cloudfront.net
VITE_IMAGE_URL_PREFIX=
VITE_PUBLIC_IMAGE_BASE_URL=
