{
  "name": "pos-minizoo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "install:all": "npm install --prefix client && npm install --prefix server && node server/scripts/ensure-pg-schema.mjs && npm run db:generate --prefix server",
    "prisma:generate": "npm run db:generate --prefix server",
    "prisma:push": "npm run db:push --prefix server",
    "prisma:validate": "npm run db:validate --prefix server",
    "build:client": "npm run build --prefix client",
    "build:vercel": "npm run db:generate --prefix server && npm run db:deploy --prefix server && npm run build --prefix client",
    "vercel-build": "npm run build:vercel",
    "db:generate": "npm run db:generate --prefix server",
    "db:deploy": "npm run db:deploy --prefix server",
    "db:migrate": "npm run db:migrate --prefix server",
    "db:push": "npm run db:push --prefix server",
    "db:seed": "npm run db:seed --prefix server"
  }
}
