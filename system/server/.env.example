# نسخ إلى .env أو .env.local — قيم Supabase من: Project Settings → Database

# محلياً: غالباً Direct أو Session (منفذ 5432) يعمل.
# على Vercel: استخدم Transaction pooler (منفذ 6543، مضيف aws-0-*.pooler.supabase.com) من لوحة Supabase
# مع ?pgbouncer=true&connection_limit=1&sslmode=require — الاتصال المباشر db.*.supabase.co:5432 غالباً يفشل (IPv6).
# اسم المستخدم في الـ pooler غالباً postgres.PROJECT_REF وليس postgres فقط (يظهر في نص الاتصال من Supabase).
# يمكن إضافة &pool_timeout=30 أو تقليل connection_limit عند خطأ P2024 (تجمع اتصالات مزدحم).
#
# مثال Supabase — Transaction pooler (مناسب لـ Vercel Serverless):
# postgresql://postgres.PROJECT_REF:[PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require
# انسخ السلسلة من Supabase → Project Settings → Database → Connection string → Transaction pooler (ليس Session ولا Direct إن كان Direct يفشل من Vercel).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

JWT_SECRET="غيّر-هذا-إلى-سلسلة-عشوائية-طويلة"

# سر لإنشاء شركة جديدة عبر POST /api/auth/register-organization (8+ أحرف). لا ترفعه للعميل.
# ORG_REGISTRATION_SECRET="ضع-سلسلة-عشوائية-طويلة"

# لوحة إدارة المنصة: بريد/عدة بريدات ADMIN (مفصولة بفواصل). مثال حساب مخصص في البذر: platform@petstore.local
# PLATFORM_ADMIN_EMAILS="platform@petstore.local"

# اختياري — صور المنتجات إن كانت مسارات نسبية
# PUBLIC_IMAGE_BASE_URL="https://xxx.supabase.co/storage/v1/object/public/..."
